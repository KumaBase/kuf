{
  "productName": "kuf",
  "version": "0.1.0",
  "identifier": "com.kuma.kuf",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "kuf",
        "width": 1200,
        "height": 800
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: https://asset.localhost",
      "assetProtocol": {
        "enable": true,
        "scope": {
          "allow": ["$HOME/**", "$APPCONFIG/**", "$RESOURCE/**"]
        }
      }
    }
  },
  "bundle": {
    "icon": ["icons/icon.png", "icons/icon.icns", "icons/icon.ico"]
  }
}
